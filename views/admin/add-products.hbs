{{!-- <h1>Admin Add Products</h1> --}}
<div class="container">
    <div id="right-panel" class="right-panel">
    <div class="row">
        <div class="col-md-6">
            <h2 class="text-center mt-3">Add product</h2>
            <form name="add_product" action="/admin/add-products" method="post" enctype="multipart/form-data" onsubmit="return validation()">

                <label for="">Product Name</label>
                <input type="text" name="name" class="form-control" required>

                {{!-- <label for="">Catagory</label>
                <input type="text" name="catagory" class="form-control"> --}}

                

                <label for="">Description</label>
                <input type="text" name="description" class="form-control" required>

                <label for="">Price</label>
                <input type="number" name="price" class="form-control" required>

                <label for="">Image</label>
                <input type="file" name="Image" class="form-control" required><br>

                <select class="form-select" name="category" aria-label="Default select example" id="select">
                    <option selected>Select Category</option>
                    {{#each catDetails}}

                    <option value="{{this.category}}">{{this.category}}</option>
                    {{/each}}
                </select><br>


                <button type="submit" class="btn btn-success mt-3" value="submit" >Submit</button>
            </form>
        </div>
    </div>
    </div>
</div>


<script>
var img = document.forms['add_product']['Image'];
var validExt = ["jpeg","png", "jpg"];
function validation(){

  if(img.value !=''){
    var img_ext = img.value.substring(img.value.lastIndexOf('.')+1);

    var result = validExt.includes(img_ext);
    if(result === false){
      Swal.fire({
  icon: 'error',
  title: 'Oops...',
  text: 'Selected file is Not Image',
  
})
      return false
    }

  }else{
     Swal.fire({
  icon: 'error',
  title: 'Oops...',
  text: 'No Images Selected',
  
})
    return false
  }
  return true;
}

</script>